# Override the config directory.
# Default: ~/.config/quire (Linux/macOS) or %APPDATA%\quire (Windows).
# QUIRE_CONFIG_HOME=

# Default profile name. Lets one machine hold multiple Quire accounts
# (work + personal) — each gets its own credentials.<profile>.json file.
# Default: "default".
# QUIRE_PROFILE=

# Override the Quire API server (useful for staging environments).
# Default: https://quire.io
# QUIRE_API_SERVER=

# Disable the auto-update check that runs on every invocation.
# Set to any non-empty value to opt out.
# QUIRE_NO_UPDATE_CHECK=
